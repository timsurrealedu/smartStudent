{
  "manifest_version": 3,
  "name": "SmartStudent BinusMaya Sync",
  "version": "1.0.0",
  "description": "Automatically syncs course, assignment, and grade data from BinusMaya to SmartStudent.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "notifications",
    "alarms",
    "webRequest"
  ],
  "host_permissions": [
    "https://lms.binus.ac.id/*",
    "https://binusmaya.binus.ac.id/*",
    "https://*.binus.ac.id/*",
    "https://apim-bm7-prod-web.azure-api.net/*",
    "https://apim-bm7-prod.azure-api.net/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://lms.binus.ac.id/*",
        "https://binusmaya.binus.ac.id/*"
      ],
      "js": [
        "extractor.js",
        "content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://lms.binus.ac.id/*",
        "https://binusmaya.binus.ac.id/*"
      ],
      "js": [
        "sniffer.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
